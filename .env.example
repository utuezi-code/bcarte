# Neon (Postgres) — Dashboard > Connect > Connection string
# Connexion poolée (pgbouncer), utilisée à l'exécution par l'app
DATABASE_URL="postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Connexion directe (non poolée), utilisée par `prisma migrate dev` comme base fantôme
DIRECT_URL="postgresql://user:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require"

# Secret de signature des sessions (JWT) — générer une valeur aléatoire forte, ex: openssl rand -base64 32
JWT_SECRET="change-me"
